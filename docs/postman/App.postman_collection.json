{
  "info": {
    "_postman_id": "a1b2c3d4-0002-0002-0002-000000000002",
    "name": "App API",
    "description": "Complete collection for the App API technical assessment.\n\n**Setup**\n1. Import `App.postman_environment.json` and select the *App API — Local* environment.\n2. Run the *Login* request — the `accessToken` variable is set automatically.\n3. All authenticated requests pick up the token from the environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register — Initiate",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register/initiate", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register", "initiate"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"phoneNumber\": \"+201111111111\",\n  \"password\": \"Test@1234\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Register — Verify OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register/verify-otp", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register", "verify-otp"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"+201111111111\",\n  \"otp\": \"123456\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.succeeded && json.data && json.data.accessToken) {",
                  "    pm.environment.set('accessToken', json.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "Register — Resend OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register/resend-otp", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register", "resend-otp"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"+201111111111\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{demoEmail}}\",\n  \"password\": \"{{demoPassword}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.succeeded && json.data && json.data.accessToken) {",
                  "    pm.environment.set('accessToken', json.data.accessToken);",
                  "    console.log('Token saved to environment.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/projects", "host": ["{{baseUrl}}"], "path": ["api", "projects"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My New Project\",\n  \"description\": \"A project created via Postman.\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.succeeded && json.data && json.data.id) {",
                  "    pm.environment.set('projectId', json.data.id);",
                  "    console.log('projectId set:', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/projects?page=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects"],
              "query": [
                { "key": "page",     "value": "1" },
                { "key": "pageSize", "value": "10" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Project by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/projects/{{projectId}}", "host": ["{{baseUrl}}"], "path": ["api", "projects", "{{projectId}}"] }
          },
          "response": []
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/projects/{{projectId}}", "host": ["{{baseUrl}}"], "path": ["api", "projects", "{{projectId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Project Name\",\n  \"description\": \"Updated description.\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/projects/{{projectId}}", "host": ["{{baseUrl}}"], "path": ["api", "projects", "{{projectId}}"] }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/projects/{{projectId}}/tasks", "host": ["{{baseUrl}}"], "path": ["api", "projects", "{{projectId}}", "tasks"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My First Task\",\n  \"description\": \"Task created via Postman.\",\n  \"priority\": \"High\",\n  \"dueDate\": \"2026-12-31\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.succeeded && json.data && json.data.id) {",
                  "    pm.environment.set('taskId', json.data.id);",
                  "    console.log('taskId set:', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "List Tasks",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/projects/{{projectId}}/tasks?page=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects", "{{projectId}}", "tasks"],
              "query": [
                { "key": "page",     "value": "1" },
                { "key": "pageSize", "value": "10" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/projects/{{projectId}}/tasks/{{taskId}}", "host": ["{{baseUrl}}"], "path": ["api", "projects", "{{projectId}}", "tasks", "{{taskId}}"] }
          },
          "response": []
        },
        {
          "name": "Update Task Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/projects/{{projectId}}/tasks/{{taskId}}/status", "host": ["{{baseUrl}}"], "path": ["api", "projects", "{{projectId}}", "tasks", "{{taskId}}", "status"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"InProgress\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/projects/{{projectId}}/tasks/{{taskId}}", "host": ["{{baseUrl}}"], "path": ["api", "projects", "{{projectId}}", "tasks", "{{taskId}}"] }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Root",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""] }
          },
          "response": []
        }
      ]
    }
  ],
  "variable": []
}
